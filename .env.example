# Язык приложения по умолчанию (en или ru)
VITE_DEFAULT_LANGUAGE=en

# Настройки Supabase – замените на URL вашего проекта и анонимный ключ
# Их можно найти в настройках проекта Supabase (раздел API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Режим мок-данных: укажите 'true', чтобы использовать тестовые данные без реального бэкенда
VITE_USE_MOCK=true